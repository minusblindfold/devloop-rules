#!/usr/bin/env bash
# Manage rule packs for devloop
set -euo pipefail

PACKS_DIR="$HOME/devloop/rule-packs"
RULES_DIR="$HOME/devloop/rules"

# ── Logging ──────────────────────────────────────────────────────────────────
ok() { echo "  [ ok ] $1"; }
warn() { echo "  [warn] $1"; }

# ── Color helpers ────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  _bold='\033[1m'
  _dim='\033[2m'
  _green='\033[32m'
  _yellow='\033[33m'
  _cyan='\033[36m'
  _reset='\033[0m'
else
  _bold='' _dim='' _green='' _yellow='' _cyan='' _reset=''
fi

# ── Helpers ──────────────────────────────────────────────────────────────────
ensure_dirs() {
  mkdir -p "$PACKS_DIR"
  mkdir -p "$RULES_DIR"
}

# Find the repo root for this script (walk up to .git)
find_repo_root() {
  local dir="$1"
  while [[ "$dir" != "/" ]]; do
    [[ -d "$dir/.git" ]] && echo "$dir" && return
    dir="$(dirname "$dir")"
  done
  return 1
}

# List pack directories in a repo (excluding _template)
list_packs_in() {
  local repo_dir="$1"
  local packs_dir="$repo_dir/packs"
  [[ -d "$packs_dir" ]] || return 0
  for pack in "$packs_dir"/*/; do
    [[ -d "$pack" ]] || continue
    local name
    name="$(basename "$pack")"
    [[ "$name" == _template ]] && continue
    echo "$name"
  done
}

# Extract one-line description from a rule's blockquote (> line after H1)
rule_desc() {
  local file="$1"
  sed -n '/^> /{s/^> *//;p;q;}' "$file" 2>/dev/null
}

# Count .md rule files in a directory (excluding rules.md)
rule_count() {
  local dir="$1"
  local count=0
  for f in "$dir"/*.md; do
    [[ -f "$f" ]] || continue
    [[ "$(basename "$f")" == "rules.md" ]] && continue
    count=$((count + 1))
  done
  echo "$count"
}

# Truncate string to max length, adding … if needed
truncate() {
  local str="$1" max="${2:-40}"
  if [[ ${#str} -gt $max ]]; then
    echo "${str:0:$((max - 1))}…"
  else
    echo "$str"
  fi
}

# List rule names in a directory (excluding rules.md), comma-separated
rule_names() {
  local dir="$1"
  local names=()
  for f in "$dir"/*.md; do
    [[ -f "$f" ]] || continue
    [[ "$(basename "$f")" == "rules.md" ]] && continue
    names+=("$(basename "$f" .md)")
  done
  local IFS=','
  echo "${names[*]}" | sed 's/,/, /g'
}

# Print a table row
print_row() {
  local icon="$1" name="$2" count="$3" rules="$4"
  rules="$(truncate "$rules" 44)"
  printf "  %b  ${_bold}%-18s${_reset} ${_dim}%2s${_reset}  ${_dim}%s${_reset}\n" "$icon" "$name" "$count" "$rules"
}

# ── Migration ────────────────────────────────────────────────────────────────
migrate_old_paths() {
  local old_layers="${XDG_CONFIG_HOME:-$HOME/.config}/devenv/rule-layers"
  local old_packs="$HOME/.claude/rule-packs"
  local migrated=false

  # Migrate rule-packs from ~/.claude/rule-packs/ to ~/devloop/rule-packs/
  if [[ -d "$old_packs" ]]; then
    for entry in "$old_packs"/*/; do
      [[ -e "$entry" ]] || continue
      local name
      name="$(basename "${entry%/}")"
      local dst="$PACKS_DIR/$name"
      if [[ -L "${entry%/}" ]]; then
        local target
        target="$(readlink "${entry%/}")"
        if [[ ! -e "$dst" ]]; then
          ln -sfn "$target" "$dst"
          ok "Migrated pack repo: $name → $target"
          migrated=true
        fi
      elif [[ -d "$entry" ]]; then
        if [[ ! -e "$dst" ]]; then
          cp -R "${entry%/}" "$dst"
          ok "Migrated pack repo (copy): $name"
          migrated=true
        fi
      fi
    done
  fi

  # Migrate rule-layers entries to symlinks in ~/devloop/rules/
  if [[ -f "$old_layers" ]]; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      local name
      name="$(basename "$line")"
      local dst="$RULES_DIR/$name"
      if [[ -d "$line" ]] && [[ ! -e "$dst" ]]; then
        ln -sfn "$line" "$dst"
        ok "Migrated active pack: $name → $line"
        migrated=true
      fi
    done <"$old_layers"
  fi

  # Clean up old files after successful migration
  if [[ "$migrated" == true ]]; then
    if [[ -f "$old_layers" ]]; then
      rm "$old_layers"
      ok "Removed old layers file: $old_layers"
      # Remove parent dirs if empty
      rmdir "${XDG_CONFIG_HOME:-$HOME/.config}/devenv" 2>/dev/null || true
    fi
    if [[ -d "$old_packs" ]]; then
      rm -rf "$old_packs"
      ok "Removed old packs dir: $old_packs"
    fi
    echo ""
    echo "  Migration complete. Old paths have been cleaned up."
    echo ""
  fi
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_install() {
  ensure_dirs

  # Migrate old paths if they exist
  migrate_old_paths

  # Find this script's repo and register it
  local script_dir
  local source="${BASH_SOURCE[0]}"
  while [[ -L "$source" ]]; do source="$(readlink "$source")"; done
  script_dir="$(cd "$(dirname "$source")" && pwd)"
  local repo_root
  if repo_root="$(find_repo_root "$script_dir")"; then
    local repo_name
    repo_name="$(basename "$repo_root")"
    local dst="$PACKS_DIR/$repo_name"

    if [[ -L "$dst" ]] && [[ "$(readlink "$dst")" == "$repo_root" ]]; then
      ok "Already registered: $repo_name"
    else
      [[ -L "$dst" ]] && rm "$dst"
      ln -sf "$repo_root" "$dst"
      ok "Registered: $repo_name → $repo_root"
    fi

    echo ""
    echo "  Available packs:"
    list_packs_in "$repo_root" | while read -r pack; do
      echo "    - $pack"
    done
  else
    warn "Could not detect repo root — register manually by symlinking into $PACKS_DIR"
  fi

  ok "Rules dir: $RULES_DIR"
  ok "Packs dir: $PACKS_DIR"
}

cmd_clone() {
  local url="$1"
  local repo_name
  repo_name="$(basename "$url" .git)"
  local dst="$PACKS_DIR/$repo_name"

  ensure_dirs

  if [[ -d "$dst" ]] || [[ -L "$dst" ]]; then
    warn "Already exists: $dst"
    echo "  Run 'devloop rules update' to pull latest changes."
    return 1
  fi

  git clone "$url" "$dst"
  ok "Cloned: $repo_name"

  echo ""
  echo "  Available packs:"
  list_packs_in "$dst" | while read -r pack; do
    echo "    - $pack"
  done
  echo ""
  echo "  Run 'devloop rules enable <pack>' to activate."
}

cmd_enable() {
  local pack_name="$1"
  ensure_dirs

  # Find the pack across all registered repos
  local pack_path=""
  for repo in "$PACKS_DIR"/*/; do
    [[ -d "$repo" ]] || continue
    # Resolve symlinks to find the actual repo
    local real_repo
    real_repo="$(cd "$repo" && pwd -P)"
    local candidate="$real_repo/packs/$pack_name"
    if [[ -d "$candidate" ]]; then
      pack_path="$candidate"
      break
    fi
  done

  if [[ -z "$pack_path" ]]; then
    echo "  Pack not found: $pack_name"
    echo "  Run 'devloop rules list' to see available packs."
    return 1
  fi

  local dst="$RULES_DIR/$pack_name"
  if [[ -L "$dst" ]] && [[ "$(readlink "$dst")" == "$pack_path" ]]; then
    ok "Already enabled: $pack_name"
  else
    ln -sfn "$pack_path" "$dst"
    ok "Enabled: $pack_name"
  fi

  cmd_list
}

cmd_disable() {
  local pack_name="$1"
  local dst="$RULES_DIR/$pack_name"

  if [[ ! -L "$dst" ]]; then
    warn "Not active: $pack_name"
    return 0
  fi

  rm "$dst"
  ok "Disabled: $pack_name"

  cmd_list
}

cmd_list() {
  ensure_dirs
  echo ""
  printf "  ${_bold}%-22s  %-4s  %s${_reset}\n" "PACK" "#" "RULES"

  # Project-level rules
  local project_rules="$PWD/devloop/rules"
  if [[ -d "$project_rules" ]]; then
    local count names
    count="$(rule_count "$project_rules")"
    if [[ "$count" -gt 0 ]]; then
      names="$(rule_names "$project_rules")"
      print_row "${_cyan}◆${_reset}" "project" "$count" "$names"
    fi
  fi

  # Active packs
  local found=false
  for entry in "$RULES_DIR"/*/; do
    [[ -L "${entry%/}" ]] || continue
    found=true
    local name count names
    name="$(basename "${entry%/}")"
    count="$(rule_count "${entry%/}")"
    names="$(rule_names "${entry%/}")"
    print_row "${_green}●${_reset}" "$name" "$count" "$names"
  done

  # Available (inactive) packs
  for repo in "$PACKS_DIR"/*/; do
    [[ -d "$repo" ]] || continue
    local real_repo
    real_repo="$(cd "$repo" && pwd -P)"
    list_packs_in "$real_repo" | while read -r pack; do
      local dst="$RULES_DIR/$pack"
      if [[ ! -L "$dst" ]]; then
        local pack_path="$real_repo/packs/$pack"
        local count names
        count="$(rule_count "$pack_path")"
        names="$(rule_names "$pack_path")"
        print_row "${_dim}○${_reset}" "$pack" "$count" "$names"
      fi
    done
  done

  if [[ "$found" == false ]] && [[ ! -d "$project_rules" || "$(rule_count "$project_rules" 2>/dev/null)" == "0" ]]; then
    printf "  ${_dim}(none — run 'devloop rules enable <pack>' to activate)${_reset}\n"
  fi
  echo ""
}

cmd_update() {
  if [[ ! -d "$PACKS_DIR" ]] || [[ -z "$(ls -A "$PACKS_DIR" 2>/dev/null)" ]]; then
    echo "  No rule repos to update."
    return 0
  fi

  for entry in "$PACKS_DIR"/*/; do
    [[ -d "$entry" ]] || continue
    local real_path
    real_path="$(cd "$entry" && pwd -P)"
    local name
    name="$(basename "$entry")"

    if [[ ! -d "$real_path/.git" ]]; then
      warn "$name: not a git repo, skipping"
      continue
    fi

    echo "  Updating $name..."
    if git -C "$real_path" pull --ff-only 2>/dev/null; then
      ok "$name: updated"
    else
      warn "$name: fast-forward failed — resolve manually in $real_path"
    fi
  done
}

# ── Usage ────────────────────────────────────────────────────────────────────
usage() {
  cat <<EOF
Usage: devloop <command> [subcommand] [args]

Commands:
  rules install                    First-time setup (register repo, create directories)
  rules clone <repo-url>           Clone a rules repo
  rules enable <pack>              Activate a rule pack
  rules disable <pack>             Deactivate a rule pack
  rules list                       Show active and available packs
  rules update                     Pull latest changes for all cloned repos
  help                             Show this help
EOF
  exit 1
}

rules_usage() {
  cat <<EOF
Usage: devloop rules <command> [args]

Commands:
  install                    First-time setup (register repo, create directories)
  clone <repo-url>           Clone a rules repo
  enable <pack>              Activate a rule pack
  disable <pack>             Deactivate a rule pack
  list                       Show active and available packs
  update                     Pull latest changes for all cloned repos
  help                       Show this help
EOF
  exit 1
}

# ── Dispatch ─────────────────────────────────────────────────────────────────
[[ $# -ge 1 ]] || usage

case "$1" in
rules)
  [[ $# -ge 2 ]] || rules_usage
  case "$2" in
  install) cmd_install ;;
  clone)
    [[ $# -ge 3 ]] || rules_usage
    cmd_clone "$3"
    ;;
  enable)
    [[ $# -ge 3 ]] || rules_usage
    cmd_enable "$3"
    ;;
  disable)
    [[ $# -ge 3 ]] || rules_usage
    cmd_disable "$3"
    ;;
  list) cmd_list ;;
  update) cmd_update ;;
  help | --help | -h) rules_usage ;;
  *) rules_usage ;;
  esac
  ;;
help | --help | -h) usage ;;
*) usage ;;
esac
